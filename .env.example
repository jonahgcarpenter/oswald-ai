# Oswald AI environment example
# Copy values into your local .env or runtime environment and fill secrets as needed.

# Gateway ports
PORT=8000
IMESSAGE_PORT=8090
IMESSAGE_WEBHOOK_PATH=/imessage/webhook

# Required WebSocket authentication
# Generate with: openssl rand -base64 32
# Signs 15-minute access JWTs. Clients pair through /auth/device and keep rotating 90-day refresh tokens.
# On a fresh database, the temporary administrator access token is printed to stdout.
WEBSOCKET_AUTH_SIGNING_KEY=
WEBSOCKET_AUTH_MAX_TOKEN_TTL=15m

# Optional iMessage / BlueBubbles gateway
# Enables iMessage only when both values are set.
BLUEBUBBLES_URL=
BLUEBUBBLES_PASSWORD=

# Optional Discord gateway
# Enables Discord only when set.
DISCORD_TOKEN=

# MCP configuration encryption
# Required at startup because the MCP store is always initialized. Use 32 raw bytes or base64-encoded 32 bytes.
# Generate one with: openssl rand -base64 32
MCP_CONFIG_ENCRYPTION_KEY=

# LLM gateway
LLM_GATEWAY_URL=http://localhost:8080
LLM_GATEWAY_MODEL=
# Optional semantic channel for hybrid durable-memory recall; FTS5 remains available without it.
LLM_GATEWAY_EMBEDDING_MODEL=
LLM_GATEWAY_API_KEY=
LLM_GATEWAY_VIRTUAL_KEY=
LLM_GATEWAY_TIMEOUT=180s

# Optional model budget overrides
# Leave as 0 to use discovered model metadata or package defaults.
MODEL_CONTEXT_WINDOW=0
MODEL_MAX_OUTPUT_TOKENS=0

# Web search backend
SEARXNG_URL=http://localhost:8080

# Runtime behavior
WORKER_POOL_SIZE=1
MAX_TOOL_FAILURE_RETRIES=3
LOG_LEVEL=info

# Memory retention and maintenance
# Durations use Go duration syntax. All values must be positive.
# Tombstone retention must be at least audit/job content retention; dead-job retention
# must be at least successful-job retention; optimize interval must be at least maintenance interval.
MEMORY_BACKGROUND_EXTRACTION_ENABLED=true
MEMORY_FORGOTTEN_CONTENT_GRACE=720h
MEMORY_CONTENT_BEARING_AUDIT_JOB_RETENTION=720h
MEMORY_CONTENT_FREE_TOMBSTONE_RETENTION=8760h
MEMORY_RETIRED_INDEX_RETENTION=168h
MEMORY_SESSION_INACTIVITY=24h
MEMORY_CANDIDATE_CONTENT_RETENTION=720h
MEMORY_SUCCESSFUL_JOB_RETENTION=168h
MEMORY_DEAD_JOB_RETENTION=720h
MEMORY_ACCOUNT_CHALLENGE_GRACE=24h
MEMORY_MAINTENANCE_INTERVAL=1h
MEMORY_DATABASE_OPTIMIZE_INTERVAL=24h
MEMORY_MAINTENANCE_BATCH_SIZE=100
