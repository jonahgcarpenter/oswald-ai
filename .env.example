# Oswald AI environment example
# Copy values into your local .env or runtime environment and fill secrets as needed.

# Gateway ports
PORT=8000
IMESSAGE_PORT=8090
IMESSAGE_WEBHOOK_PATH=/imessage/webhook

# Optional iMessage / BlueBubbles gateway
# Enables iMessage only when both values are set.
BLUEBUBBLES_URL=
BLUEBUBBLES_PASSWORD=

# Optional Discord gateway
# Enables Discord only when set.
DISCORD_TOKEN=

# MCP configuration encryption
# Required for DB-backed MCP server configs. Use 32 raw bytes or base64-encoded 32 bytes.
# Generate one with: openssl rand -base64 32
MCP_CONFIG_ENCRYPTION_KEY=

# LLM gateway
LLM_GATEWAY_URL=http://localhost:8080
LLM_GATEWAY_MODEL=
LLM_GATEWAY_EMBEDDING_MODEL=
LLM_GATEWAY_API_KEY=
LLM_GATEWAY_VIRTUAL_KEY=
LLM_GATEWAY_TIMEOUT=180s

# Optional model budget overrides
# Leave as 0 to use discovered model metadata or package defaults.
MODEL_CONTEXT_WINDOW=0
MODEL_MAX_OUTPUT_TOKENS=0

# Web search backend
SEARXNG_URL=http://localhost:8080

# Runtime behavior
WORKER_POOL_SIZE=1
MAX_TOOL_FAILURE_RETRIES=3
LOG_LEVEL=info
